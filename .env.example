# ─── Base de datos (Supabase PostgreSQL) ──────────────────────────────────────
# Obtener en: supabase.com → proyecto → Settings → Database → Connection string
# DATABASE_URL usa pgbouncer (connection pooling) — para la app en producción
# DIRECT_URL es la conexión directa — para migraciones con Prisma
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generar secreto seguro con: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
# En producción usar el dominio real; en local usar http://localhost:3000
NEXTAUTH_URL="https://microkapital.com"

# ─── Cloudinary (almacenamiento de documentos e imágenes) ─────────────────────
# Obtener en: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Super Admin (dueño del sistema) ──────────────────────────────────────────
SUPER_ADMIN_EMAIL="admin@microkapital.com"
SUPER_ADMIN_PANEL_PATH="/sys-mnt-9x7k/panel"

# ─── Admin de operaciones (puede deshacer pagos y editar fechas pagadas) ───────
# Poner aquí el email exacto de Stephanie. Solo este usuario verá los controles
# de "Deshacer pago" y podrá editar fechas de filas Pagado/Vencido/cualquier estado.
OPERATIONS_ADMIN_EMAIL="stephanie@microkapital.com"
