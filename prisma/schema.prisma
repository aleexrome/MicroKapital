generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  DIRECTOR_GENERAL // Aprueba créditos, cambia fechas de pago
  DIRECTOR_COMERCIAL // Visualización total, sin aprobación
  GERENTE_ZONAL // Verifica transferencias, activa créditos de su zona
  COORDINADOR // Asesor de campo — gestiona sus propios clientes
  // Roles legacy (mantener hasta migración completa de datos)
  GERENTE
  COBRADOR
  CLIENTE
}

enum LicenseStatus {
  ACTIVE
  SUSPENDED
  GRACE
  CANCELLED
}

enum LoanType {
  SOLIDARIO
  INDIVIDUAL
  AGIL
  FIDUCIARIO
}

enum LoanStatus {
  PENDING_APPROVAL
  APPROVED // Aprobado por Director General — pendiente de activación
  IN_ACTIVATION // Cliente aceptó condiciones — coordinador transita los 3 candados
  ACTIVE
  LIQUIDATED
  REJECTED
  RESTRUCTURED
  DEFAULTED
  DECLINED // Activación cancelada antes de completar (después de IN_ACTIVATION)
}

enum ScheduleStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
  ADVANCE
  FINANCIADO // Pago cubierto por renovación anticipada — se muestra en morado
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RegisterStatus {
  OPEN
  CLOSED
}

enum ScoreEventType {
  ON_TIME
  ADVANCE
  LOAN_COMPLETED
  LATE_1_7
  LATE_8_15
  LATE_16_PLUS
  DEFAULT
}

enum DocumentType {
  INE_FRONT
  INE_BACK
  PHOTO
  CONTRACT
  PROOF_ADDRESS
  OTHER
}

// ─────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────

model Company {
  id        String   @id @default(uuid())
  nombre    String
  logoUrl   String?
  telefono  String?
  email     String?
  direccion String?
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  license       License?
  branches      Branch[]
  users         User[]
  clients       Client[]
  loans         Loan[]
  tickets       Ticket[]
  notifications Notification[]
  settings      CompanySetting[]
  bankAccounts  CompanyBankAccount[]
  goals         Goal[]
}

model License {
  id                 String        @id @default(uuid())
  companyId          String        @unique
  company            Company       @relation(fields: [companyId], references: [id])
  claveLicencia      String        @unique
  estado             LicenseStatus @default(ACTIVE)
  precioMensual      Decimal       @db.Decimal(10, 2)
  diaCobro           Int
  proximoPago        DateTime
  ultimaVerificacion DateTime      @default(now())
  notasInternas      String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Branch {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  nombre    String
  direccion String?
  telefono  String?
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())

  users         User[]
  clients       Client[]
  loans         Loan[]
  loanGroups    LoanGroup[]
  cashRegisters CashRegister[]
  tickets       Ticket[]
}

model User {
  id           String    @id @default(uuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])
  branchId     String?
  branch       Branch?   @relation(fields: [branchId], references: [id])
  rol          UserRole
  nombre       String
  email        String
  passwordHash String
  telefono     String?
  activo       Boolean   @default(true)
  ultimoAcceso DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Jerarquía: COORDINADOR apunta a su GERENTE_ZONAL
  gerenteId           String?
  gerente             User?   @relation("GerenteCoordinadores", fields: [gerenteId], references: [id])
  coordinadores       User[]  @relation("GerenteCoordinadores")
  // GERENTE_ZONAL: lista de IDs de sucursales de su zona (JSON array de strings)
  zonaBranchIds       Json?
  // Permiso especial: puede aplicar / deshacer pagos en su sucursal (sin ser DG/SA)
  permisoAplicarPagos Boolean @default(false)

  clientsManaged              Client[]                    @relation("CobradoresClientes")
  clientUser                  Client?                     @relation("ClienteUsuario")
  payments                    Payment[]
  cashRegisters               CashRegister[]
  ticketsPrinted              Ticket[]
  auditLogs                   AuditLog[]
  loansApproved               Loan[]                      @relation("ApprovedLoans")
  loansRejected               Loan[]                      @relation("RejectedLoans")
  loansCobrador               Loan[]                      @relation("CobradoresLoans")
  loanGroups                  LoanGroup[]
  approvalReviewer            LoanApproval[]              @relation("ReviewerApprovals")
  approvalRequest             LoanApproval[]              @relation("RequesterApprovals")
  uploadedDocs                ClientDocument[]
  loanDocuments               LoanDocument[]
  scoreEvents                 ScoreEvent[]
  transfersVerified           Payment[]                   @relation("VerifiedTransfers")
  // Solicitudes de cancelación por limbo (anti-fraude)
  solicitudesCancelacionLimbo SolicitudCancelacionLimbo[] @relation("SolicitanteCancelacion")
  decisionesCancelacionLimbo  SolicitudCancelacionLimbo[] @relation("AprobadorCancelacion")

  @@unique([companyId, email])
}

model Client {
  id                 String    @id @default(uuid())
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id])
  branchId           String
  branch             Branch    @relation(fields: [branchId], references: [id])
  cobradorId         String?
  cobrador           User?     @relation("CobradoresClientes", fields: [cobradorId], references: [id])
  userId             String?   @unique
  user               User?     @relation("ClienteUsuario", fields: [userId], references: [id])
  nombreCompleto     String
  numIne             String?
  curp               String?
  telefono           String?
  telefonoAlt        String?
  email              String?
  domicilio          String?
  referenciaNombre   String?
  referenciaTelefono String?
  fechaNacimiento    DateTime?
  fotoUrl            String?
  score              Int       @default(500)
  activo             Boolean   @default(true)
  // Soft delete: si DG borra al cliente se setea esta fecha. El cliente
  // queda invisible en cartera/agenda/rutas. Cron purga a los 14 días.
  eliminadoEn        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  documents       ClientDocument[]
  loans           Loan[]
  payments        Payment[]
  scoreEvents     ScoreEvent[]
  coberturasOtras Payment[]        @relation("CoberturaGrupal")
}

model ClientDocument {
  id          String       @id @default(uuid())
  clientId    String
  client      Client       @relation(fields: [clientId], references: [id])
  subidoPor   String
  uploadedBy  User         @relation(fields: [subidoPor], references: [id])
  tipo        DocumentType
  archivoUrl  String
  descripcion String?
  createdAt   DateTime     @default(now())
}

model LoanGroup {
  id          String    @id @default(uuid())
  branchId    String
  branch      Branch    @relation(fields: [branchId], references: [id])
  cobradorId  String
  cobrador    User      @relation(fields: [cobradorId], references: [id])
  nombre      String
  activo      Boolean   @default(true)
  // Soft delete (mismo patrón que Client). Cron purga a los 14 días.
  eliminadoEn DateTime?
  createdAt   DateTime  @default(now())

  loans Loan[]
}

model Loan {
  id                     String         @id @default(uuid())
  companyId              String
  company                Company        @relation(fields: [companyId], references: [id])
  branchId               String
  branch                 Branch         @relation(fields: [branchId], references: [id])
  cobradorId             String
  cobrador               User           @relation("CobradoresLoans", fields: [cobradorId], references: [id])
  clientId               String
  client                 Client         @relation(fields: [clientId], references: [id])
  loanGroupId            String?
  loanGroup              LoanGroup?     @relation(fields: [loanGroupId], references: [id])
  tipo                   LoanType
  estado                 LoanStatus     @default(PENDING_APPROVAL)
  // Montos
  capital                Decimal        @db.Decimal(12, 2)
  comision               Decimal        @default(0) @db.Decimal(12, 2)
  montoReal              Decimal        @db.Decimal(12, 2)
  tasaInteres            Decimal        @db.Decimal(6, 4)
  interes                Decimal        @db.Decimal(12, 2)
  totalPago              Decimal        @db.Decimal(12, 2)
  pagoSemanal            Decimal?       @db.Decimal(12, 2)
  pagoDiario             Decimal?       @db.Decimal(12, 2)
  pagoQuincenal          Decimal?       @db.Decimal(12, 2) // FIDUCIARIO: 12 quincenas
  // Plazos
  plazo                  Int
  fechaDesembolso        DateTime?
  fechaPrimerPago        DateTime? // Fecha ancla del calendario — definida por DG en contrapropuesta
  diaPago                String? // Día de cobro: "DOMINGO", "LUNES", etc.
  // Campos de comportamiento (para cálculo de comisiones y tasas)
  ciclo                  Int            @default(1) // INDIVIDUAL: número de ciclo (1, 2, 3…)
  tuvoAtraso             Boolean        @default(false) // INDIVIDUAL: afecta comisión de renovación
  clienteIrregular       Boolean        @default(false) // ÁGIL: determina tasa $65 o $75
  tipoGrupo              String? // SOLIDARIO: "REGULAR" o "RESCATE"
  // Campos FIDUCIARIO
  tipoGarantia           String? // "MUEBLE" o "INMUEBLE"
  descripcionGarantia    String?
  valorGarantia          Decimal?       @db.Decimal(12, 2)
  // Checklist de documentos (JSON array of {id, label, checked})
  documentChecklist      Json?
  // DG solicita documentación antes de activar
  requiereDocumentos     Boolean        @default(false)
  // Seguro de apertura
  seguro                 Decimal?       @db.Decimal(12, 2) // Monto del seguro cobrado
  seguroMetodoPago       PaymentMethod? // CASH | TRANSFER
  seguroPendiente        Boolean        @default(false) // Seguro por transferencia pendiente de verificación por gerente
  // Evidencia de desembolso
  desembolsoFotoUrl      String? // URL de la foto (Cloudinary)
  desembolsoLat          Float? // Latitud GPS del desembolso
  desembolsoLng          Float? // Longitud GPS del desembolso
  desembolsoFotoAt       DateTime? // Cuándo se subió la evidencia
  // Aval
  avalNombre             String?
  avalTelefono           String?
  avalRelacion           String? // "CONYUGE", "FAMILIAR", "CONOCIDO", etc.
  // Aprobación
  aprobadoPorId          String?
  aprobadoPor            User?          @relation("ApprovedLoans", fields: [aprobadoPorId], references: [id])
  aprobadoAt             DateTime?
  rechazadoPorId         String?
  rechazadoPor           User?          @relation("RejectedLoans", fields: [rechazadoPorId], references: [id])
  razonRechazo           String?
  notas                  String?
  // Flujo secuencial de activación (Fase 6 — 3 candados)
  activationStartedAt    DateTime?
  activationCanceledAt   DateTime?
  activationCanceledBy   String?
  activationCancelReason String?
  // Renovación anticipada
  loanOriginalId         String? // ID del crédito que se está renovando
  loanOriginal           Loan?          @relation("LoanRenewal", fields: [loanOriginalId], references: [id])
  loanRenovado           Loan[]         @relation("LoanRenewal")
  descuentoRenovacion    Decimal?       @db.Decimal(12, 2) // Monto financiado descontado del nuevo crédito
  pagosFinanciadosIds    Json? // IDs de PaymentSchedule del crédito anterior que pasan a FINANCIADO al activar
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  schedule                  PaymentSchedule[]
  payments                  Payment[]
  approvals                 LoanApproval[]
  scoreEvents               ScoreEvent[]
  documents                 LoanDocument[]
  // Anti-fraude: alertas escalonadas y solicitudes de cancelación
  notificacionesLimbo       NotificacionLimbo[]
  solicitudCancelacionLimbo SolicitudCancelacionLimbo?
}

model LoanDocument {
  id          String   @id @default(uuid())
  loanId      String
  loan        Loan     @relation(fields: [loanId], references: [id])
  subidoPor   String
  uploadedBy  User     @relation(fields: [subidoPor], references: [id])
  tipo        String // "SOLICITUD", "INE_FRENTE", "INE_REVERSO", "COMPROBANTE_DOMICILIO", "CONTRATO", "PAGARE", "FOTO", "AVAL_INE", "OTRO"
  archivoUrl  String
  descripcion String?
  createdAt   DateTime @default(now())
}

model LoanApproval {
  id              String         @id @default(uuid())
  loanId          String
  loan            Loan           @relation(fields: [loanId], references: [id])
  solicitadoPorId String
  solicitadoPor   User           @relation("RequesterApprovals", fields: [solicitadoPorId], references: [id])
  revisadoPorId   String?
  revisadoPor     User?          @relation("ReviewerApprovals", fields: [revisadoPorId], references: [id])
  estado          ApprovalStatus @default(PENDING)
  notas           String?
  solicitadoAt    DateTime       @default(now())
  revisadoAt      DateTime?
}

model PaymentSchedule {
  id               String         @id @default(uuid())
  loanId           String
  loan             Loan           @relation(fields: [loanId], references: [id])
  numeroPago       Int
  fechaVencimiento DateTime
  montoEsperado    Decimal        @db.Decimal(12, 2)
  montoPagado      Decimal        @default(0) @db.Decimal(12, 2)
  estado           ScheduleStatus @default(PENDING)
  pagadoAt         DateTime?
  createdAt        DateTime       @default(now())

  payments Payment[]

  @@unique([loanId, numeroPago])
}

model Payment {
  id                  String              @id @default(uuid())
  loanId              String
  loan                Loan                @relation(fields: [loanId], references: [id])
  scheduleId          String?
  schedule            PaymentSchedule?    @relation(fields: [scheduleId], references: [id])
  cobradorId          String
  cobrador            User                @relation(fields: [cobradorId], references: [id])
  clientId            String
  client              Client              @relation(fields: [clientId], references: [id])
  monto               Decimal             @db.Decimal(12, 2)
  metodoPago          PaymentMethod
  cambioEntregado     Decimal             @default(0) @db.Decimal(12, 2)
  notas               String?
  fechaHora           DateTime            @default(now())
  createdAt           DateTime            @default(now())
  // Cancelación (Fase 6 — botón "Atrás" del candado 2 de activación)
  canceledAt          DateTime?
  // Transferencia bancaria
  cuentaDestinoId     String?
  cuentaDestino       CompanyBankAccount? @relation(fields: [cuentaDestinoId], references: [id])
  idTransferencia     String? // Referencia/ID de la transferencia
  statusTransferencia String? // "PENDIENTE" | "VERIFICADO"
  verificadoPorId     String?
  verificadoPor       User?               @relation("VerifiedTransfers", fields: [verificadoPorId], references: [id])
  verificadoAt        DateTime?
  // Cobertura solidaria (grupo Solidario)
  esCoberturaGrupal   Boolean             @default(false)
  cubridoPorClienteId String?
  cubridoPor          Client?             @relation("CoberturaGrupal", fields: [cubridoPorClienteId], references: [id])
  montoPropio         Decimal?            @db.Decimal(12, 2) // su parte individual
  montoCubierto       Decimal?            @db.Decimal(12, 2) // lo que cubrió de otra

  cashBreakdown CashBreakdown[]
  tickets       Ticket[]
}

model CashBreakdown {
  id           String  @id @default(uuid())
  paymentId    String
  payment      Payment @relation(fields: [paymentId], references: [id])
  denominacion Int
  cantidad     Int
  subtotal     Decimal @db.Decimal(10, 2)
}

model CompanyBankAccount {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  banco        String
  titular      String
  numeroCuenta String
  clabe        String
  activa       Boolean  @default(true)
  createdAt    DateTime @default(now())

  payments Payment[]
}

model Ticket {
  id               String   @id @default(uuid())
  paymentId        String
  payment          Payment  @relation(fields: [paymentId], references: [id])
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])
  branchId         String
  branch           Branch   @relation(fields: [branchId], references: [id])
  numeroTicket     String   @unique
  impresoPorId     String
  impresoPor       User     @relation(fields: [impresoPorId], references: [id])
  esReimpresion    Boolean  @default(false)
  ticketOriginalId String?
  ticketOriginal   Ticket?  @relation("TicketReprintOf", fields: [ticketOriginalId], references: [id])
  reimpresiones    Ticket[] @relation("TicketReprintOf")
  razonReimpresion String?
  anulado          Boolean  @default(false)
  razonAnulacion   String?
  qrCode           String?
  impresoAt        DateTime @default(now())
}

model CashRegister {
  id                   String         @id @default(uuid())
  cobradorId           String
  cobrador             User           @relation(fields: [cobradorId], references: [id])
  branchId             String
  branch               Branch         @relation(fields: [branchId], references: [id])
  fecha                DateTime       @db.Date
  efectivoInicial      Decimal        @default(0) @db.Decimal(12, 2)
  cobrosEsperados      Decimal        @default(0) @db.Decimal(12, 2)
  cobradoEfectivo      Decimal        @default(0) @db.Decimal(12, 2)
  cobradoTarjeta       Decimal        @default(0) @db.Decimal(12, 2)
  cobradoTransferencia Decimal        @default(0) @db.Decimal(12, 2)
  cambioEntregado      Decimal        @default(0) @db.Decimal(12, 2)
  efectivoFinal        Decimal?       @db.Decimal(12, 2)
  diferencia           Decimal?       @db.Decimal(12, 2)
  estado               RegisterStatus @default(OPEN)
  notas                String?
  cerradoAt            DateTime?
  cerradoPorId         String?
  createdAt            DateTime       @default(now())

  @@unique([cobradorId, fecha])
}

model ScoreEvent {
  id              String         @id @default(uuid())
  clientId        String
  client          Client         @relation(fields: [clientId], references: [id])
  loanId          String
  loan            Loan           @relation(fields: [loanId], references: [id])
  paymentId       String?
  registradoPorId String
  registradoPor   User           @relation(fields: [registradoPorId], references: [id])
  tipoEvento      ScoreEventType
  diasDiferencia  Int?
  cambioScore     Int
  scoreResultado  Int
  createdAt       DateTime       @default(now())
}

model CompanySetting {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  branchId    String?
  clave       String
  valor       String
  descripcion String?
  updatedAt   DateTime @updatedAt

  @@unique([companyId, branchId, clave])
}

model AuditLog {
  id                String   @id @default(uuid())
  userId            String?
  user              User?    @relation(fields: [userId], references: [id])
  accion            String
  tabla             String
  registroId        String?
  valoresAnteriores Json?
  valoresNuevos     Json?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
}

// ─────────────────────────────────────────
// METAS — Reportes / cumplimiento semanal
// ─────────────────────────────────────────
//
// Una Goal define KPIs esperados para un periodo semanal. Definida por
// DG/DC (en /reportes/metas), evaluada en /reportes/cumplimiento contra
// datos reales (loans, payments, cartera).
//
// Granularidad: branchId/cobradorId/loanType opcionales.
//   - Todos null    → meta global de empresa
//   - branchId set  → meta por sucursal
//   - cobradorId    → meta individual del cobrador
//   - loanType set  → meta acotada al producto (SOLIDARIO/AGIL/etc.)
//
// Todos los campos meta* son opcionales: si no se define, ese KPI no se
// evalúa en cumplimiento (no penaliza).
model Goal {
  id         String    @id @default(uuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id])
  branchId   String?
  cobradorId String?
  loanType   LoanType?

  // Periodo (semanal). semanaInicio = lunes 00:00, semanaFin = domingo 23:59
  semanaInicio DateTime @db.Date
  semanaFin    DateTime @db.Date

  // KPIs (todos opcionales — si null no se evalúa)
  metaCapitalColocado   Decimal? @db.Decimal(14, 2)
  metaCreditosColocados Int?
  metaCobranzaEsperada  Decimal? @db.Decimal(14, 2)
  metaCobranzaEfectiva  Decimal? @db.Decimal(14, 2)
  metaMoraMaxima        Decimal? @db.Decimal(5, 2) // % (ej: 5.00 = 5%)
  metaCrecimiento       Decimal? @db.Decimal(5, 2) // % cartera vs semana anterior

  notas       String?
  creadoPorId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, semanaInicio])
  @@index([branchId])
  @@index([cobradorId])
}

model Notification {
  id         String    @id @default(uuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id])
  userId     String?
  clientId   String?
  loanId     String?
  tipo       String
  titulo     String
  mensaje    String
  enviadoVia String?
  enviado    Boolean   @default(false)
  enviadoAt  DateTime?
  // Notificaciones críticas (ej. préstamo en limbo > 72h) NO se pueden marcar
  // como leídas ni ocultar — se mantienen hasta que la condición se resuelva.
  esCritica  Boolean   @default(false)
  // Clasificación visual: CRITICA (rojo, no marcable) | IMPORTANTE (amarillo) |
  // INFORMATIVA (gris). Para CRITICA siempre va con esCritica=true.
  nivel      String    @default("INFORMATIVA")
  // URL a la que navega al hacer click (si aplica). Si es null y hay loanId,
  // se navega a /prestamos/<loanId> por convención.
  linkUrl    String?
  // Notificaciones no críticas se descartan después de N días para no
  // ensuciar la bandeja. NULL = no expira (críticas).
  expiraAt   DateTime? @db.Timestamptz(3)
  // Cuándo el usuario abrió/marcó la notificación. NULL = no leída.
  // Las críticas (esCritica=true) NO pueden marcarse como leídas — siempre
  // mantienen leidaAt=NULL hasta que se borren.
  leidaAt    DateTime? @db.Timestamptz(3)
  createdAt  DateTime  @default(now())

  @@index([userId, leidaAt])
  @@index([userId, nivel])
}

// ─────────────────────────────────────────
// MÓDULO DE CONTRATOS (Fase 1)
// Aditivo: no modifica modelos ni enums existentes
// ─────────────────────────────────────────

model Contract {
  id             String @id @default(uuid())
  loanId         String @unique
  numeroContrato String @unique

  // Snapshot al momento de generación
  representanteLegal String
  lugarFirma         String
  diaCobro           String
  horaLimiteCobro    String
  fechaFirma         DateTime

  // PDF generado (sin firmar)
  pdfGeneradoUrl String
  generadoAt     DateTime
  generadoPorId  String

  // Vínculo al LoanDocument cuando se sube el firmado
  loanDocumentFirmadoId String? @unique

  companyId String
  branchId  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groupMembers ContractGroupMember[]

  @@index([companyId])
  @@index([branchId])
}

model ContractGroupMember {
  id               String   @id @default(uuid())
  contractId       String
  contract         Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  loanId           String   @unique
  esCoordinadora   Boolean  @default(false)
  ordenLista       Int
  nombreIntegrante String
  montoIntegrante  Decimal  @db.Decimal(12, 2)

  @@unique([contractId, loanId])
  @@unique([contractId, ordenLista])
  @@index([loanId])
}

model CompanyContractConfig {
  id                 String   @id @default(uuid())
  companyId          String   @unique
  representanteLegal String
  cat                Decimal  @default(100.00) @db.Decimal(5, 2)
  interesMoratorio   Decimal  @default(10.00) @db.Decimal(5, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model BranchContractConfig {
  id              String   @id @default(uuid())
  branchId        String   @unique
  codigoSucursal  String   @unique
  ciudad          String
  diaCobro        String
  horaLimiteCobro String
  folioYear       Int      @default(2026)
  folioLastNumber Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────────────────────────────────
// MÓDULO DE NOTIFICACIONES Y BLOQUEO POR LIMBO
// Sistema anti-fraude: detecta préstamos APPROVED/IN_ACTIVATION
// estancados y notifica/bloquea según horas transcurridas.
// ─────────────────────────────────────────

model NotificacionLimbo {
  id               String   @id @default(uuid())
  loanId           String
  // '12h' | '24h' | '36h' | '48h' | '60h' | '72h' | 'cancelacion'
  tipoNotificacion String
  // IDs de Users a quienes se notificó. Para auditoría retro: si después
  // cambia la jerarquía, sabemos a quién se avisó originalmente.
  destinatariosIds String[]
  enviadaAt        DateTime @default(now()) @db.Timestamptz(3)

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  // Garantiza que el cron NO duplique la misma alerta para el mismo loan.
  @@unique([loanId, tipoNotificacion])
  @@index([loanId])
}

model SolicitudCancelacionLimbo {
  id                 String    @id @default(uuid())
  loanId             String    @unique
  solicitadoPor      String
  motivo             String    @db.Text
  // PENDIENTE | APROBADA | RECHAZADA
  estado             String    @default("PENDIENTE")
  aprobadoPor        String?
  decididoAt         DateTime? @db.Timestamptz(3)
  comentarioDecision String?   @db.Text
  createdAt          DateTime  @default(now()) @db.Timestamptz(3)

  loan        Loan  @relation(fields: [loanId], references: [id], onDelete: Cascade)
  solicitante User  @relation("SolicitanteCancelacion", fields: [solicitadoPor], references: [id])
  aprobador   User? @relation("AprobadorCancelacion", fields: [aprobadoPor], references: [id])
}
