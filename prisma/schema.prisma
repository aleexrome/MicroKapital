generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  DIRECTOR_GENERAL // Aprueba créditos, cambia fechas de pago
  DIRECTOR_COMERCIAL // Visualización total, sin aprobación
  MESA_CONTROL // Revisa expedientes de solicitudes antes de la aprobación de DG
  GERENTE_ZONAL // Verifica transferencias, activa créditos de su zona
  COORDINADOR // Asesor de campo — gestiona sus propios clientes
  // Roles legacy (mantener hasta migración completa de datos)
  GERENTE
  COBRADOR
  CLIENTE
}

enum LicenseStatus {
  ACTIVE
  SUSPENDED
  GRACE
  CANCELLED
}

enum LoanType {
  SOLIDARIO
  INDIVIDUAL
  AGIL
  FIDUCIARIO
}

enum LoanStatus {
  PENDING_REVIEW // Recién capturada por coordinador — esperando revisión de Mesa de Control
  RETURNED_TO_COORDINATOR // Mesa de Control regresó con observaciones al coordinador
  PENDING_APPROVAL // Mesa de Control aprobó — esperando decisión de Dirección General
  APPROVED // Aprobado por Director General — pendiente de activación
  IN_ACTIVATION // Cliente aceptó condiciones — coordinador transita los 3 candados
  ACTIVE
  LIQUIDATED
  REJECTED
  RESTRUCTURED
  DEFAULTED
  DECLINED // Activación cancelada antes de completar (después de IN_ACTIVATION)
}

enum ScheduleStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
  ADVANCE
  FINANCIADO // Pago cubierto por renovación anticipada — se muestra en morado
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RegisterStatus {
  OPEN
  CLOSED
}

enum ScoreEventType {
  ON_TIME
  ADVANCE
  LOAN_COMPLETED
  LATE_1_7
  LATE_8_15
  LATE_16_PLUS
  DEFAULT
}

enum DocumentType {
  INE_FRONT
  INE_BACK
  PHOTO
  CONTRACT
  PROOF_ADDRESS
  OTHER
}

// ─────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────

model Company {
  id        String   @id @default(uuid())
  nombre    String
  logoUrl   String?
  telefono  String?
  email     String?
  direccion String?
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  license       License?
  branches      Branch[]
  users         User[]
  clients       Client[]
  loans         Loan[]
  tickets       Ticket[]
  notifications Notification[]
  settings      CompanySetting[]
  bankAccounts  CompanyBankAccount[]
  goals         Goal[]
  employees     EmployeeRecord[]
  extraFunds    BranchExtraFund[]
  withdrawals   BranchWithdrawal[]
  moraCobros    MoraCobro[]
}

model License {
  id                 String        @id @default(uuid())
  companyId          String        @unique
  company            Company       @relation(fields: [companyId], references: [id])
  claveLicencia      String        @unique
  estado             LicenseStatus @default(ACTIVE)
  precioMensual      Decimal       @db.Decimal(10, 2)
  diaCobro           Int
  proximoPago        DateTime
  ultimaVerificacion DateTime      @default(now())
  notasInternas      String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Branch {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  nombre    String
  direccion String?
  telefono  String?
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())

  users         User[]
  clients       Client[]
  loans         Loan[]
  loanGroups    LoanGroup[]
  cashRegisters CashRegister[]
  tickets       Ticket[]
  extraFunds    BranchExtraFund[]
  withdrawals   BranchWithdrawal[]
  moraCobros    MoraCobro[]
  bancaViewers  User[]             @relation("BancaViewers")
}

// Aporte adicional que Dirección envía a una sucursal fuera del ciclo
// normal de préstamos. En /banca se suma a los cortes y modifica el
// "Neto para banca" — refleja movimientos de tesorería tipo "DG mandó
// $50k extra a Toluca esta semana".
model BranchExtraFund {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  fecha       DateTime @db.Date
  monto       Decimal  @db.Decimal(12, 2)
  concepto    String?
  createdById String
  createdBy   User     @relation("BranchExtraFundsCreated", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([branchId, fecha])
  @@index([companyId, fecha])
}

// Retiro de recurso que Dirección hace desde una sucursal — espejo
// negativo de BranchExtraFund. En /banca se resta del "Neto para
// banca" — refleja movimientos tipo "DG retiró $30k de Toluca para
// llevar a otra sucursal / gastos operativos".
model BranchWithdrawal {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  fecha       DateTime @db.Date
  monto       Decimal  @db.Decimal(12, 2)
  concepto    String?
  createdById String
  createdBy   User     @relation("BranchWithdrawalsCreated", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([branchId, fecha])
  @@index([companyId, fecha])
}

model User {
  id           String    @id @default(uuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])
  branchId     String?
  branch       Branch?   @relation(fields: [branchId], references: [id])
  rol          UserRole
  nombre       String
  email        String
  passwordHash String
  telefono     String?
  activo       Boolean   @default(true)
  ultimoAcceso DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Jerarquía: COORDINADOR apunta a su GERENTE_ZONAL
  gerenteId           String?
  gerente             User?   @relation("GerenteCoordinadores", fields: [gerenteId], references: [id])
  coordinadores       User[]  @relation("GerenteCoordinadores")
  // GERENTE_ZONAL: lista de IDs de sucursales de su zona (JSON array de strings)
  zonaBranchIds       Json?
  // Permiso especial: puede aplicar / deshacer pagos en su sucursal (sin ser DG/SA)
  permisoAplicarPagos Boolean @default(false)
  // Acceso de solo lectura a /banca filtrado a UNA sucursal específica.
  // Se usa para dar a coordinadores / gerentes zonales visibilidad de
  // la banca de su sucursal sin permitirles crear adicionales / retiros.
  // null = sin acceso (default).
  bancaViewerBranchId String?
  bancaViewerBranch   Branch? @relation("BancaViewers", fields: [bancaViewerBranchId], references: [id])

  clientsManaged              Client[]                    @relation("CobradoresClientes")
  clientsHeredadosDe          Client[]                    @relation("HeredadoDeCoordinador")
  clientUser                  Client?                     @relation("ClienteUsuario")
  payments                    Payment[]
  cashRegisters               CashRegister[]
  ticketsPrinted              Ticket[]
  auditLogs                   AuditLog[]
  loansApproved               Loan[]                      @relation("ApprovedLoans")
  loansRejected               Loan[]                      @relation("RejectedLoans")
  loansRevised                Loan[]                      @relation("RevisedLoans")
  loansCobrador               Loan[]                      @relation("CobradoresLoans")
  loanGroups                  LoanGroup[]
  approvalReviewer            LoanApproval[]              @relation("ReviewerApprovals")
  approvalRequest             LoanApproval[]              @relation("RequesterApprovals")
  uploadedDocs                ClientDocument[]
  loanDocuments               LoanDocument[]
  scoreEvents                 ScoreEvent[]
  transfersVerified           Payment[]                   @relation("VerifiedTransfers")
  // Solicitudes de cancelación por limbo (anti-fraude)
  solicitudesCancelacionLimbo SolicitudCancelacionLimbo[] @relation("SolicitanteCancelacion")
  decisionesCancelacionLimbo  SolicitudCancelacionLimbo[] @relation("AprobadorCancelacion")
  extraFundsCreated           BranchExtraFund[]           @relation("BranchExtraFundsCreated")
  withdrawalsCreated          BranchWithdrawal[]          @relation("BranchWithdrawalsCreated")
  morasGeneradas              MoraCobro[]                 @relation("MorasGeneradas")

  @@unique([companyId, email])
}

model Client {
  id                 String    @id @default(uuid())
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id])
  branchId           String
  branch             Branch    @relation(fields: [branchId], references: [id])
  cobradorId         String?
  cobrador           User?     @relation("CobradoresClientes", fields: [cobradorId], references: [id])
  userId             String?   @unique
  user               User?     @relation("ClienteUsuario", fields: [userId], references: [id])
  // Trazabilidad: cuando se reasigna un cliente a otro coordinador,
  // guardamos el coordinador de origen y la fecha del cambio. En la UI
  // se muestra solo el badge "Heredado" (sin exponer al coord original).
  // En BD sí queda quién lo tenía para reportes internos y auditoría.
  heredadoDeId       String?
  heredadoDe         User?     @relation("HeredadoDeCoordinador", fields: [heredadoDeId], references: [id])
  heredadoAt         DateTime?
  nombreCompleto     String
  numIne             String?
  curp               String?
  telefono           String?
  telefonoAlt        String?
  email              String?
  domicilio          String?
  referenciaNombre   String?
  referenciaTelefono String?
  fechaNacimiento    DateTime?
  fotoUrl            String?
  score              Int       @default(500)
  activo             Boolean   @default(true)
  // Soft delete: si DG borra al cliente se setea esta fecha. El cliente
  // queda invisible en cartera/agenda/rutas. Cron purga a los 14 días.
  eliminadoEn        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  documents       ClientDocument[]
  loans           Loan[]
  payments        Payment[]
  scoreEvents     ScoreEvent[]
  coberturasOtras Payment[]        @relation("CoberturaGrupal")
  moraCobros      MoraCobro[]
}

model ClientDocument {
  id           String       @id @default(uuid())
  clientId     String
  client       Client       @relation(fields: [clientId], references: [id])
  subidoPor    String
  uploadedBy   User         @relation(fields: [subidoPor], references: [id])
  tipo         DocumentType
  archivoUrl   String
  descripcion  String?
  // Observación de Mesa de Control (nula si aún no la revisó). Se sobrescribe
  // en cada revisión; no guardamos historial de observaciones previas.
  revisionNota String?
  revisadoAt   DateTime?
  createdAt    DateTime     @default(now())
}

model LoanGroup {
  id          String    @id @default(uuid())
  branchId    String
  branch      Branch    @relation(fields: [branchId], references: [id])
  cobradorId  String
  cobrador    User      @relation(fields: [cobradorId], references: [id])
  nombre      String
  activo      Boolean   @default(true)
  // Soft delete (mismo patrón que Client). Cron purga a los 14 días.
  eliminadoEn DateTime?
  createdAt   DateTime  @default(now())

  loans Loan[]
}

model Loan {
  id                     String         @id @default(uuid())
  companyId              String
  company                Company        @relation(fields: [companyId], references: [id])
  branchId               String
  branch                 Branch         @relation(fields: [branchId], references: [id])
  cobradorId             String
  cobrador               User           @relation("CobradoresLoans", fields: [cobradorId], references: [id])
  clientId               String
  client                 Client         @relation(fields: [clientId], references: [id])
  loanGroupId            String?
  loanGroup              LoanGroup?     @relation(fields: [loanGroupId], references: [id])
  tipo                   LoanType
  estado                 LoanStatus     @default(PENDING_APPROVAL)
  // Montos
  capital                Decimal        @db.Decimal(12, 2)
  comision               Decimal        @default(0) @db.Decimal(12, 2)
  montoReal              Decimal        @db.Decimal(12, 2)
  tasaInteres            Decimal        @db.Decimal(6, 4)
  interes                Decimal        @db.Decimal(12, 2)
  totalPago              Decimal        @db.Decimal(12, 2)
  pagoSemanal            Decimal?       @db.Decimal(12, 2)
  pagoDiario             Decimal?       @db.Decimal(12, 2)
  pagoQuincenal          Decimal?       @db.Decimal(12, 2) // FIDUCIARIO: 12 quincenas
  // Plazos
  plazo                  Int
  fechaDesembolso        DateTime?
  fechaPrimerPago        DateTime? // Fecha ancla del calendario — definida por DG en contrapropuesta
  diaPago                String? // Día de cobro: "DOMINGO", "LUNES", etc.
  // Campos de comportamiento (para cálculo de comisiones y tasas)
  ciclo                  Int            @default(1) // INDIVIDUAL: número de ciclo (1, 2, 3…)
  tuvoAtraso             Boolean        @default(false) // INDIVIDUAL: afecta comisión de renovación
  clienteIrregular       Boolean        @default(false) // ÁGIL: determina tasa $65 o $75
  tipoGrupo              String? // SOLIDARIO: "REGULAR" o "RESCATE"
  // SOLIDARIO: el integrante elegido por DG como coordinadora del grupo.
  // El loan del coordinador es el ancla del contrato y desde el que se
  // dispara la activación grupal (foto + comisiones se propagan al resto).
  esCoordinadora         Boolean        @default(false)
  // Día (LUNES..DOMINGO) y hora límite (HH:MM 24h) de cobro definidos por
  // DG al aprobar este préstamo. Se plasman en el contrato. Antes venían
  // del BranchContractConfig por sucursal; ahora son por-préstamo para que
  // DG decida según el cliente. BranchContractConfig sigue como fallback
  // para créditos viejos donde estos campos quedaron en NULL.
  diaCobro               String?
  horaLimiteCobro        String?
  // Campos FIDUCIARIO
  tipoGarantia           String? // "MUEBLE" o "INMUEBLE"
  descripcionGarantia    String?
  valorGarantia          Decimal?       @db.Decimal(12, 2)
  // Checklist de documentos (JSON array of {id, label, checked})
  documentChecklist      Json?
  // DG solicita documentación antes de activar
  requiereDocumentos     Boolean        @default(false)
  // Seguro de apertura
  seguro                 Decimal?       @db.Decimal(12, 2) // Monto del seguro cobrado
  seguroMetodoPago       PaymentMethod? // CASH | TRANSFER
  seguroPendiente        Boolean        @default(false) // Seguro por transferencia pendiente de verificación por gerente
  // Evidencia de desembolso
  desembolsoFotoUrl      String? // URL de la foto (Cloudinary)
  desembolsoLat          Float? // Latitud GPS del desembolso
  desembolsoLng          Float? // Longitud GPS del desembolso
  desembolsoFotoAt       DateTime? // Cuándo se subió la evidencia
  // Aval
  avalNombre             String?
  avalTelefono           String?
  avalTelefonoAlt        String?
  avalDireccion          String?
  avalRelacion           String? // "CONYUGE", "FAMILIAR", "CONOCIDO", etc.
  // Aprobación
  aprobadoPorId          String?
  aprobadoPor            User?          @relation("ApprovedLoans", fields: [aprobadoPorId], references: [id])
  aprobadoAt             DateTime?
  rechazadoPorId         String?
  rechazadoPor           User?          @relation("RejectedLoans", fields: [rechazadoPorId], references: [id])
  razonRechazo           String?
  notas                  String?
  // Mesa de Control — revisión intermedia entre creación y aprobación de DG.
  // revisionNotasGenerales: observaciones libres que Mesa de Control redacta
  // sobre la solicitud (visibles al coordinador cuando el préstamo regresa).
  // revisadoPorId / revisadoAt: quién decidió el último cambio de estado
  // (forward a DG o regreso al coordinador).
  revisionNotasGenerales String?
  revisadoPorId          String?
  revisadoPor            User?          @relation("RevisedLoans", fields: [revisadoPorId], references: [id])
  revisadoAt             DateTime?
  // Flujo secuencial de activación (Fase 6 — 3 candados)
  activationStartedAt    DateTime?
  activationCanceledAt   DateTime?
  activationCanceledBy   String?
  activationCancelReason String?
  // Renovación anticipada
  loanOriginalId         String? // ID del crédito que se está renovando
  loanOriginal           Loan?          @relation("LoanRenewal", fields: [loanOriginalId], references: [id])
  loanRenovado           Loan[]         @relation("LoanRenewal")
  descuentoRenovacion    Decimal?       @db.Decimal(12, 2) // Monto financiado descontado del nuevo crédito
  pagosFinanciadosIds    Json? // IDs de PaymentSchedule del crédito anterior que pasan a FINANCIADO al activar
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  schedule                  PaymentSchedule[]
  payments                  Payment[]
  approvals                 LoanApproval[]
  scoreEvents               ScoreEvent[]
  documents                 LoanDocument[]
  // Anti-fraude: alertas escalonadas y solicitudes de cancelación
  notificacionesLimbo       NotificacionLimbo[]
  solicitudCancelacionLimbo SolicitudCancelacionLimbo?
  moraCobros                MoraCobro[]
}

model LoanDocument {
  id           String   @id @default(uuid())
  loanId       String
  loan         Loan     @relation(fields: [loanId], references: [id])
  subidoPor    String
  uploadedBy   User     @relation(fields: [subidoPor], references: [id])
  tipo         String // "SOLICITUD", "INE_FRENTE", "INE_REVERSO", "COMPROBANTE_DOMICILIO", "CONTRATO", "PAGARE", "FOTO", "AVAL_INE", "OTRO"
  archivoUrl   String
  descripcion  String?
  // Observación de Mesa de Control (nula si aún no la revisó). Se sobrescribe
  // en cada revisión; no guardamos historial de observaciones previas.
  revisionNota String?
  revisadoAt   DateTime?
  createdAt    DateTime @default(now())
}

model LoanApproval {
  id              String         @id @default(uuid())
  loanId          String
  loan            Loan           @relation(fields: [loanId], references: [id])
  solicitadoPorId String
  solicitadoPor   User           @relation("RequesterApprovals", fields: [solicitadoPorId], references: [id])
  revisadoPorId   String?
  revisadoPor     User?          @relation("ReviewerApprovals", fields: [revisadoPorId], references: [id])
  estado          ApprovalStatus @default(PENDING)
  notas           String?
  solicitadoAt    DateTime       @default(now())
  revisadoAt      DateTime?
}

model PaymentSchedule {
  id               String         @id @default(uuid())
  loanId           String
  loan             Loan           @relation(fields: [loanId], references: [id])
  numeroPago       Int
  fechaVencimiento DateTime
  montoEsperado    Decimal        @db.Decimal(12, 2)
  montoPagado      Decimal        @default(0) @db.Decimal(12, 2)
  estado           ScheduleStatus @default(PENDING)
  pagadoAt         DateTime?
  createdAt        DateTime       @default(now())

  payments   Payment[]
  moraCobros MoraCobro[]

  @@unique([loanId, numeroPago])
}

// Registro de multa ($200 después de 2 PM del día del pago) o mora
// ($500 al día siguiente en adelante). No bloquea nada — solo se
// contabiliza. El cobrador puede marcar cobrada = true al capturar
// el pago principal, en cuyo caso se crea un Payment adicional
// (paymentCobroId) con su propio ticket. Si no la cobra, queda
// registrada como pendiente para reportes.
model MoraCobro {
  id             String   @id @default(uuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])
  branchId       String
  branch         Branch   @relation(fields: [branchId], references: [id])
  loanId         String
  loan           Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  scheduleId     String
  schedule       PaymentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id])
  cobradorId     String
  cobrador       User     @relation("MorasGeneradas", fields: [cobradorId], references: [id])
  // MULTA ($200 mismo día después de 14:00 CDMX) | MORA ($500 en día
  // posterior). No se acumula: solo una por schedule.
  tipo           String
  monto          Decimal  @db.Decimal(12, 2)
  // Payment que disparó la generación (el pago tardío del schedule).
  // Nullable porque la mora puede capturarse ANTES de que se pague el
  // pago principal — el coordinador puede cobrar mora sola y el pago
  // se aplica después. El @unique aplica solo entre valores no-null
  // en Postgres, así que múltiples null no chocan.
  paymentOrigenId String?  @unique
  paymentOrigen   Payment? @relation("PaymentGeneraMora", fields: [paymentOrigenId], references: [id], onDelete: Cascade)
  // Si el cobrador cobró la multa/mora en el mismo request, aquí el
  // Payment que la respalda. Null si no se cobró.
  paymentCobroId String?  @unique
  paymentCobro   Payment? @relation("PaymentCobroMora", fields: [paymentCobroId], references: [id], onDelete: SetNull)
  cobrada        Boolean  @default(false)
  cobradaAt      DateTime?
  createdAt      DateTime @default(now())

  @@unique([scheduleId])
  @@index([companyId, createdAt])
  @@index([branchId, createdAt])
  @@index([cobradorId, createdAt])
  @@index([loanId])
}

model Payment {
  id                  String              @id @default(uuid())
  loanId              String
  loan                Loan                @relation(fields: [loanId], references: [id])
  scheduleId          String?
  schedule            PaymentSchedule?    @relation(fields: [scheduleId], references: [id])
  cobradorId          String
  cobrador            User                @relation(fields: [cobradorId], references: [id])
  clientId            String
  client              Client              @relation(fields: [clientId], references: [id])
  monto               Decimal             @db.Decimal(12, 2)
  metodoPago          PaymentMethod
  cambioEntregado     Decimal             @default(0) @db.Decimal(12, 2)
  notas               String?
  fechaHora           DateTime            @default(now())
  createdAt           DateTime            @default(now())
  // Cancelación (Fase 6 — botón "Atrás" del candado 2 de activación)
  canceledAt          DateTime?
  // Transferencia bancaria
  cuentaDestinoId     String?
  cuentaDestino       CompanyBankAccount? @relation(fields: [cuentaDestinoId], references: [id])
  idTransferencia     String? // Referencia/ID de la transferencia
  statusTransferencia String? // "PENDIENTE" | "VERIFICADO"
  verificadoPorId     String?
  verificadoPor       User?               @relation("VerifiedTransfers", fields: [verificadoPorId], references: [id])
  verificadoAt        DateTime?
  // Cobertura solidaria (grupo Solidario)
  esCoberturaGrupal   Boolean             @default(false)
  cubridoPorClienteId String?
  cubridoPor          Client?             @relation("CoberturaGrupal", fields: [cubridoPorClienteId], references: [id])
  montoPropio         Decimal?            @db.Decimal(12, 2) // su parte individual
  montoCubierto       Decimal?            @db.Decimal(12, 2) // lo que cubrió de otra

  cashBreakdown CashBreakdown[]
  tickets       Ticket[]
  // Relaciones con MoraCobro:
  //   PaymentGeneraMora  → este Payment fue el que disparó la multa/mora.
  //   PaymentCobroMora   → este Payment respalda el cobro de la multa/mora.
  moraGenerada  MoraCobro?     @relation("PaymentGeneraMora")
  moraCobrada   MoraCobro?     @relation("PaymentCobroMora")
}

model CashBreakdown {
  id           String  @id @default(uuid())
  paymentId    String
  payment      Payment @relation(fields: [paymentId], references: [id])
  denominacion Int
  cantidad     Int
  subtotal     Decimal @db.Decimal(10, 2)
}

model CompanyBankAccount {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  banco        String
  titular      String
  numeroCuenta String
  clabe        String
  activa       Boolean  @default(true)
  createdAt    DateTime @default(now())

  payments Payment[]
}

model Ticket {
  id               String   @id @default(uuid())
  paymentId        String
  payment          Payment  @relation(fields: [paymentId], references: [id])
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])
  branchId         String
  branch           Branch   @relation(fields: [branchId], references: [id])
  numeroTicket     String   @unique
  impresoPorId     String
  impresoPor       User     @relation(fields: [impresoPorId], references: [id])
